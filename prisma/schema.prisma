// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  firstName    String?
  lastName     String?
  role         Role     @default(CLIENT)
  isSuspended  Boolean  @default(false)
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  tokenVersion Int      @default(0)
  // Multi-tenant preparation (null = mono-tenant MVP)
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Security: audit trail for login attempts
  loginAttempts LoginAttempt[]
  // Password reset tokens
  passwordResets PasswordReset[]
  // Audit logs
  auditLogs AuditLog[]
  // Phase 2
  services      Service[]
  clientNotes   AdminNote[]              // notes écrites à propos de ce client
  adminNotes    AdminNote[] @relation("AdminNotes") // notes écrites par cet admin

  @@index([email])
  @@index([role])
  @@index([tenantId])
}

enum Role {
  ADMIN
  CLIENT
}

// Security audit trail for login attempts (Phase 1 requirement)
model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([email])
  @@index([createdAt])
}

// Global platform settings (created once during setup wizard)
model SystemSettings {
  id              String   @id @default(cuid())
  platformName    String   @default("ZoutaCMS")
  platformUrl     String?
  isSetupComplete Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Security: DB-backed rate limiting per IP
model RateLimitEntry {
  ip                  String    @id
  count               Int       @default(0)
  resetAt             DateTime
  consecutiveFailures Int       @default(0)
  blockedUntil        DateTime?
  updatedAt           DateTime  @updatedAt
}

// Security audit log for sensitive actions + admin action journal
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  // Phase 2: admin action journal fields (nullable for backward compat)
  entity    String?
  entityId  String?
  ip        String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// Phase 2 — Services
model Service {
  id          String        @id @default(cuid())
  name        String
  type        ServiceType
  status      ServiceStatus @default(PENDING)
  config      Json
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Phase 4 — Provider integration
  externalId  String?       // ID chez le provider (ex: VM ID Proxmox)
  providerId  String?       // Référence vers ProviderConfig
  provider    ProviderConfig? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  provisionError String?    // Détail de l'erreur si provisionnement échoué
  provisionAttempts Int     @default(0)
  nextRetryAt DateTime?
  // Phase 5 — Monitoring
  healthChecks HealthCheck[]
  alerts       Alert[]
  // Multi-tenant preparation
  tenantId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([providerId])
  @@index([tenantId])
}

enum ServiceType {
  VPS
  MINECRAFT
}

enum ServiceStatus {
  PENDING
  PROVISIONING
  PROVISIONING_FAILED
  PROVISIONING_TIMEOUT
  REQUIRES_MANUAL_CHECK
  ACTIVE
  SUSPENDED
  TERMINATING
  TERMINATED
}

// Phase 4 — Provider plugin configuration
model ProviderConfig {
  id        String    @id @default(cuid())
  provider  String    // "proxmox", "hetzner", "pelican"
  name      String    // Nom affiché (ex: "Proxmox Node 1")
  config    Json      // URL, token, params spécifiques (chiffrés)
  isActive  Boolean   @default(true)
  services  Service[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([provider])
  @@index([isActive])
}

// Phase 2 — Notes internes admin sur un client
model AdminNote {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User     @relation("AdminNotes", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([adminId])
}

// Phase 5 — Monitoring
model HealthCheck {
  id        String            @id @default(cuid())
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status    HealthCheckStatus
  latency   Int?
  metrics   Json?             // { cpu, ram, ramUsed, ramTotal, diskTotal, netIn, netOut }
  error     String?
  checkedAt DateTime          @default(now())

  @@index([serviceId])
  @@index([checkedAt])
}

enum HealthCheckStatus {
  UP
  DOWN
  DEGRADED
}

model Alert {
  id         String    @id @default(cuid())
  serviceId  String
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  type       String    // "down", "up", "degraded"
  message    String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([serviceId])
  @@index([resolvedAt])
}

model AlertConfig {
  id             String   @id @default("singleton")
  panelEnabled   Boolean  @default(true)
  discordEnabled Boolean  @default(false)
  discordWebhook String?
  updatedAt      DateTime @updatedAt
}

// Password reset tokens
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}
