# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/zoutacms

# Auth (NextAuth.js)
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Chiffrement des secrets en base (AES-256-GCM - min 32 caractères)
ENCRYPTION_KEY=changeme-32-chars-minimum-required

# Stripe (Phase 6)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Redis (Phase 4+ si BullMQ)
REDIS_URL=redis://localhost:6379

# Mode mock pour les tests
USE_MOCKS=false
